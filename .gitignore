# Workspace-level gitignore

# Node modules (any subdirectory)
**/node_modules/

# Next.js build cache
app/.next/
app/next-env.d.ts
app/tsconfig.tsbuildinfo

# Convex generated
app/convex/_generated/

# Environment
app/.env.local
app/.env*.local

# Temp dirs
_tmp_directory_repo/

# Drive watcher local state
.drive-manifest.json

# WCORWIN build output (Cloudflare Pages builds from source)
seo-engine/WCORWIN/dist/

# Archive (old scripts, concepts, reports)
_archive/

# Agent outbox archives
*/outbox/_archive/

# Test demos
lobe/test-demo/

# Sensitive files
*.bin
browser-agent/.env
.claude/worktrees/

# Session files
*/.last-session

# Browser agent screenshots (ephemeral QA artifacts)
browser-agent/shots/*.png
sentinel/shots/*.png

# Agent dirs (migrated to ~/agents/)
dispatch/
funkie/
convex-agent/
ink/
email-agent/
pm/

# Lobe agent files (keep components/ and cron/ which are FJ-specific)
lobe/*.ts
lobe/package*.json
lobe/tsconfig.json
lobe/CLAUDE.md
lobe/inbox/
lobe/outbox/
lobe/memory/

# SEO Engine agent files (keep WCORWIN/ which is FJ-specific)
seo-engine/*.ts
seo-engine/package*.json
seo-engine/tsconfig.json
seo-engine/CLAUDE.md
seo-engine/inbox/
seo-engine/outbox/
seo-engine/memory/
seo-engine/context/

# Sentinel agent files (keep shots/ which is FJ-specific)
sentinel/*.ts
sentinel/package*.json
sentinel/CLAUDE.md
sentinel/inbox/
sentinel/outbox/
sentinel/memory/
